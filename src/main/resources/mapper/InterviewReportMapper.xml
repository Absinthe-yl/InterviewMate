<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.interviewmate.mapper.InterviewReportMapper">

    <resultMap id="BaseResultMap" type="org.interviewmate.entity.InterviewReport">
        <id column="id" property="id"/>
        <result column="session_id" property="sessionId"/>
        <result column="strengths" property="strengths"/>
        <result column="weaknesses" property="weaknesses"/>
        <result column="suggestions" property="suggestions"/>
        <result column="overall_comment" property="overallComment"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, session_id, strengths, weaknesses, suggestions, overall_comment, created_at
    </sql>

    <insert id="insert" parameterType="org.interviewmate.entity.InterviewReport">
        INSERT INTO interview_report (session_id, strengths, weaknesses, suggestions, overall_comment, created_at)
        VALUES (#{sessionId}, #{strengths}, #{weaknesses}, #{suggestions}, #{overallComment}, NOW())
    </insert>

    <select id="findBySessionId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM interview_report
        WHERE session_id = #{sessionId}
    </select>

    <delete id="deleteBySessionId">
        DELETE FROM interview_report WHERE session_id = #{sessionId}
    </delete>

</mapper>