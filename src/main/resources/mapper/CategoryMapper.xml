<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.interviewmate.mapper.CategoryMapper">

    <resultMap id="BaseResultMap" type="org.interviewmate.entity.Category">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <insert id="insert" parameterType="org.interviewmate.entity.Category" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO category (name, sort_order, created_at)
        VALUES (#{name}, #{sortOrder}, NOW())
    </insert>

    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM category WHERE id = #{id}
    </select>

    <select id="findAll" resultMap="BaseResultMap">
        SELECT * FROM category ORDER BY sort_order ASC
    </select>

    <select id="countKnowledgeByCategoryId" resultType="int">
        SELECT COUNT(*) FROM knowledge WHERE category_id = #{categoryId} AND status = 1
    </select>

</mapper>